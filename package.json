{
  "name": "gustwind",
  "version": "0.0.0",
  "type": "module",
  "description": "Gustwind is a [Deno](https://deno.land/) powered website creator that allows component oriented development of large scale sites. Conceptually it's split as follows:",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Use deno task test for unit tests or npm run test:e2e for Playwright.\" && exit 1",
    "build:node": "node ./gustwind-node/cli.ts --build --output ./build",
    "build:node:check": "node ./gustwind-node/cli.ts --build --output ./.tmp-node-build",
    "dev:node": "node ./gustwind-node/cli.ts --develop --port 3000",
    "test:node:dev": "node --test ./gustwind-node/dev_test.ts",
    "test:node:serve": "node --test ./gustwind-node/serve_test.ts",
    "serve:node": "node ./gustwind-node/cli.ts --serve --input ./build --port 3000",
    "typecheck": "deno task check:types",
    "quality:gate": "deno task quality:gate",
    "cf:build": "./build.sh",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:dev": "wrangler dev",
    "test:e2e": "npm --prefix e2e run test",
    "test:e2e:headed": "npm --prefix e2e run test:headed"
  },
  "keywords": [],
  "author": "Juho Vepsäläinen",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/typography": "0.5.15",
    "autoprefixer": "10.4.20",
    "cssnano": "7.0.6",
    "gray-matter": "4.0.3",
    "highlight.js": "11.11.1",
    "htm": "3.1.1",
    "marked": "16.4.0",
    "pagefind": "1.3.0",
    "postcss": "8.4.49",
    "sharp": "0.34.3",
    "tailwindcss": "3.4.15"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@netlify/functions": "2.4.0",
    "esbuild": "0.28.0",
    "vite": "8.0.8",
    "wrangler": "4.80.0"
  }
}
