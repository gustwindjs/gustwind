{
  "name": "gustwind",
  "version": "0.0.0",
  "type": "module",
  "description": "Gustwind is a Node.js-powered website creator that allows component-oriented development of large-scale sites.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Use npm run quality:gate for the full verification suite or npm run test:e2e for Playwright.\" && exit 1",
    "build": "npm run build:node",
    "build:node": "node ./gustwind-node/cli.ts --build --output ./build",
    "build:node:check": "node ./gustwind-node/cli.ts --build --output ./.tmp-node-build",
    "build:npm:gustwind": "deno run --no-lock --node-modules-dir=auto -A build_gustwind_for_npm.ts",
    "build:npm:htmlisp": "deno run --no-lock --node-modules-dir=auto -A build_htmlisp_for_npm.ts",
    "dev": "npm run dev:node",
    "dev:node": "node ./gustwind-node/cli.ts --develop --port 3000",
    "start": "npm run dev:node",
    "start:netlify": "netlify dev",
    "test:node:render": "node --test ./gustwind-node/mod_test.ts ./gustwind-node/build_test.ts",
    "test:node:dev": "node --test ./gustwind-node/dev_test.ts",
    "test:node:serve": "node --test ./gustwind-node/serve_test.ts",
    "test:unit": "deno test --no-lock --node-modules-dir=auto htmlisp/html-tests htmlisp/html-tests-sync routers/utilities",
    "watch:test": "deno test --no-lock --node-modules-dir=auto --watch",
    "serve": "npm run serve:node",
    "serve:node": "node ./gustwind-node/cli.ts --serve --input ./build --port 3000",
    "typecheck:code": "deno check --no-lock --node-modules-dir=auto --allow-import $(rg --files -g '*.ts' | rg -v '^(e2e/|plugins/.*/compiled-scripts/)')",
    "typecheck:e2e": "npm --prefix e2e run typecheck",
    "typecheck": "npm run typecheck:code && npm run typecheck:e2e",
    "quality:gate": "npm run typecheck && npm run test:unit && npm run test:node:render && npm run build:node:check && npm run test:node:dev && npm run test:node:serve && npm run test:e2e",
    "watch:build": "node --watch ./gustwind-node/cli.ts --build --output ./build",
    "cf:build": "./build.sh",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:dev": "wrangler dev",
    "test:e2e": "npm --prefix e2e run test",
    "test:e2e:headed": "npm --prefix e2e run test:headed"
  },
  "keywords": [],
  "author": "Juho Vepsäläinen",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/typography": "0.5.15",
    "autoprefixer": "10.4.20",
    "cssnano": "7.0.6",
    "gray-matter": "4.0.3",
    "highlight.js": "11.11.1",
    "htm": "3.1.1",
    "marked": "16.4.0",
    "pagefind": "1.3.0",
    "postcss": "8.4.49",
    "sharp": "0.34.3",
    "tailwindcss": "3.4.15"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@netlify/functions": "2.4.0",
    "esbuild": "0.28.0",
    "vite": "8.0.8",
    "wrangler": "4.80.0"
  }
}
