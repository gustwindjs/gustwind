{
  "lock": false,
  "tasks": {
    "test": "deno test",
    "check:types:deno": "deno check --allow-import $(rg --files -g '*.ts' | rg -v '^(e2e/|plugins/.*/compiled-scripts/)')",
    "check:types:e2e": "npm --prefix e2e run typecheck",
    "check:types": "deno task check:types:deno && deno task check:types:e2e",
    "test:quality": "deno test --allow-read --allow-write --allow-net --allow-env --allow-run gustwind-node/mod_test.ts && deno test htmlisp/html-tests htmlisp/html-tests-sync routers/utilities utilities/watch_test.ts",
    "quality:gate": "deno task check:types && deno task test:quality && npm run test:e2e",
    "watch:test": "deno test --watch",
    "serve": "deno run --lock=deno.server.lock --allow-sys --allow-env --allow-read --allow-net --allow-write --allow-run --allow-import ./gustwind-cli/mod.ts -s -p 3000 -i ./build",
    "start": "deno run --lock=deno.server.lock --allow-sys --allow-env --allow-ffi --allow-read --allow-net --allow-write --allow-run --allow-import ./gustwind-cli/mod.ts -d -p 3000",
    "start:netlify": "netlify dev",
    "update:start:lock": "deno run --lock=deno.server.lock --lock-write --allow-sys --allow-env --allow-ffi --allow-read --allow-net --allow-write --allow-run --allow-import ./gustwind-cli/mod.ts -d -p 3000",
    "watch:start": "deno run --lock=deno.server.lock --allow-sys --allow-env --allow-ffi --allow-read --allow-net --allow-write --allow-run --allow-import --watch ./gustwind-cli/mod.ts -d -p 3000",
    "build": "deno run --lock=deno.build.lock --allow-sys --allow-env --allow-ffi --allow-read --allow-net --allow-write --allow-run --allow-import ./gustwind-cli/mod.ts -b -t cpuMax -o ./build",
    "netlify:build": "DEBUG=1 deno run --allow-sys --allow-env --allow-ffi --allow-read --allow-net --allow-write --allow-run --allow-import ./gustwind-cli/mod.ts -b -t cpuMax -o ./build",
    "update:build:lock": "deno run --lock=deno.build.lock --lock-write --allow-sys --allow-env --allow-read --allow-net --allow-write --allow-run --allow-import ./gustwind-cli/mod.ts -b -t cpuHalf -o ./build",
    "watch:build": "deno run --lock=deno.build.lock --allow-sys --allow-env --allow-ffi --allow-read --allow-net --allow-write --allow-run --allow-import --watch ./gustwind-cli/mod.ts -b -t cpuHalf -o ./build",
    "build:gustwind-for-npm": "deno run -A build_gustwind_for_npm.ts",
    "build:htmlisp-for-npm": "deno run -A build_htmlisp_for_npm.ts"
  },
  "nodeModulesDir": "auto"
}
